generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  TRIAL
  PRO
}

enum MudancaStatus {
  RASCUNHO
  COTANDO
  CONFIRMADA
  CONCLUIDA
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String    @unique
  emailVerified          DateTime?
  image                  String?
  plan                   Plan      @default(FREE)
  trialEndsAt            DateTime?
  stripeCustomerId       String?   @unique
  stripePriceId          String?
  stripeSubscriptionId   String?   @unique
  stripeCurrentPeriodEnd DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  mudancas  Mudanca[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Item {
  id             String  @id @default(cuid())
  nome           String
  categoria      String
  iconeUrl       String
  larguraCm      Float
  alturaCm       Float
  profundidadeCm Float
  pesoKg         Float
  volumeM3       Float
  editavel       Boolean @default(true)

  mudancaItens MudancaItem[]
  cargaItens   CargaLayoutItem[]
}

model Caminhao {
  id            String  @id @default(cuid())
  nome          String
  tipo          String
  capacidadeM3  Float
  capacidadeKg  Float
  comprimentoCm Float
  larguraCm     Float
  alturaCm      Float
  imagemUrl     String?

  mudancas     Mudanca[]
  cargaLayouts CargaLayout[]
}

model Transportadora {
  id              String   @id @default(cuid())
  nome            String
  logoUrl         String?
  notaMedia       Float    @default(0)
  totalAvaliacoes Int      @default(0)
  cidade          String
  tiposCaminhao   String[]

  cotacoes Cotacao[]
}

model Mudanca {
  id              String        @id @default(cuid())
  userId          String
  enderecoOrigem  String
  enderecoDestino String
  dataDesejada    DateTime?
  caminhaoId      String?
  status          MudancaStatus @default(RASCUNHO)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  caminhao    Caminhao?     @relation(fields: [caminhaoId], references: [id])
  itens       MudancaItem[]
  cotacoes    Cotacao[]
  cargaLayout CargaLayout?
}

model MudancaItem {
  id         String @id @default(cuid())
  mudancaId  String
  itemId     String
  quantidade Int    @default(1)

  mudanca Mudanca @relation(fields: [mudancaId], references: [id], onDelete: Cascade)
  item    Item    @relation(fields: [itemId], references: [id])

  @@unique([mudancaId, itemId])
}

model Cotacao {
  id               String   @id @default(cuid())
  mudancaId        String
  transportadoraId String
  precoCentavos    Int
  dataDisponivel   DateTime
  seguroIncluso    Boolean  @default(false)
  validade         DateTime
  createdAt        DateTime @default(now())

  mudanca        Mudanca        @relation(fields: [mudancaId], references: [id], onDelete: Cascade)
  transportadora Transportadora @relation(fields: [transportadoraId], references: [id])
}

model CargaLayout {
  id                 String   @id @default(cuid())
  mudancaId          String   @unique
  caminhaoId         String
  ocupacaoPercentual Float    @default(0)
  updatedAt          DateTime @updatedAt

  mudanca Mudanca           @relation(fields: [mudancaId], references: [id], onDelete: Cascade)
  caminhao Caminhao         @relation(fields: [caminhaoId], references: [id])
  itens   CargaLayoutItem[]
}

model CargaLayoutItem {
  id            String @id @default(cuid())
  cargaLayoutId String
  itemId        String
  x             Float
  y             Float
  rotacao       Float  @default(0)

  cargaLayout CargaLayout @relation(fields: [cargaLayoutId], references: [id], onDelete: Cascade)
  item        Item        @relation(fields: [itemId], references: [id])
}
